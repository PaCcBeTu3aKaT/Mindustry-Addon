{
  "type": "AttributeGenerator",
  "name": "Гидро-генератор",
  "description": "Преобразует кинетическую энергию течения в электричество. Работает только при размещении на воде.",
  "size": 4,
  "health": 1200,

  /* Мощность при 100% эффективности (на глубокой воде) */
  "powerProduction": 12.0, 
  
  /* Привязка к воде */
  "attribute": "water",
  
  /* Критически важные настройки для гидро-блоков: */
  "baseEfficiency": 0.0,    /* На суше (где нет воды) будет выдавать 0 */
  "minEfficiency": 0.1,     /* Минимальный порог для запуска */
  "displayEfficiency": true,
  "placeableLiquid": true,  /* Разрешает установку на жидкости */

  "hasPower": true,
  "outputsPower": true,
  "requirements": [
    { "item": "copper", "amount": 120 },
    { "item": "lead", "amount": 80 },
    { "item": "graphite", "amount": 40 },
    { "item": "titanium", "amount": 20 }
  ],

  "category": "power",
  "research": "core-outpost"
}
